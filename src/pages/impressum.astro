---
import {getLang, translate} from "../i18n";
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Navbar from "../components/Nav.astro";

const lang = getLang(Astro.url);
const t = translate(lang);
---

<Layout title="Flavius Cojocariu | Web developer - resume">
    <Navbar defaultActiveItem="Impressum"></Navbar>
    <main class="container text-light">
        <div id="resume" class="d-flex px-1 py-5 justify-content-center section-height section col-12">
            <div class="d-flex flex-fill flex-column align-items-center g-5 py-5 col-sm-12">
                <div class="col-lg-12">
                    <p class="fs-1 mb-3 flex-fill text-warning fw-light text-center section-title d-print-none">
                        {t("impressum.title")}
                    </p>
                </div>
                <div class="d-flex flex-column mb-3 justify-content-center align-items-center align-self-center col-12">
                    <div class="fs-5 d-flex flex-column justify-content-center p-5 align-items-start align-self-center col-10">
                        <p>Angaben gemäß § 5 TMG</p>

                        <p><strong>Flavius Cojocariu</strong></p>
                        <p>Freiberuflicher Webentwickler · Engineering Manager · IT-Beratung</p>
                        <p>Steiner Ring 34</p>
                        <p>82538 Geretsried</p>
                        <p>Deutschland</p>

                        <p>Telefon: +49 1520 2762116 (werktags 10–16 Uhr)</p>
                        <p>E-Mail: info@flaviuscojocariu.com</p>
                        <p>Website: https://flaviuscojocariu.com</p>

                        <p><strong>Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV</strong></p>

                        <p><strong>Flavius Cojocariu</strong></p>
                        <p>Steiner Ring 34</p>
                        <p>82538 Geretsried</p>
                        <p>Deutschland</p>

                        <p><strong>Umsatzsteuer-ID</strong></p>

                        <p>Nicht umsatzsteuerpflichtig gemäß § 19 UStG (Kleinunternehmerregelung)</p>

                    </div>
                </div>
            </div>
        </div>
    </main>
    <Footer></Footer>
</Layout>

<style>
    .section-title {
        position: relative;
        padding-bottom: 8px;
    }

    .section-title::after {
        position: absolute;
        margin-left: auto;
        margin-right: auto;
        left: 0;
        right: 0;
        text-align: center;
        bottom: 0;
        width: 5vh;
        height: 1px;
        border-bottom: 7px solid #ffcc00;
        content: "";
    }

    .timeline-section {
        width: 100%;
        padding: 8px 8px 8px 25px;
    }

    .timeline-section .timeline-item {
        padding: 16px;
        margin: 16px 16px 16px 25px;
        width: 100%;
        background: #242a37;
        line-height: 2.5em !important;
    }

    .timeline-item-body, .timeline-item-body ul > li {
        padding: 8px;
        line-height: 1.75em !important;
    }

    .vh-5 {
        height: 5vh;
    }

    .max-vh-5 {
        max-height: 5vh;
    }

    .min-vh-5 {
        min-height: 5vh;
    }

    @media screen and (min-width: 900px) {

        .timeline-section {
            width: 100%;
        }

        .timeline-item {
            width: 750px;
            min-width: 750px;
            border: 2px solid #ff8900;
            position: relative;
        }

        .timeline-section {
            border-left: 5px solid #ff8900;
            padding-left: 8px;
        }

        .timeline-section .timeline-item::before {
            content: "";
            border: 3px solid #ff8900;
            border-radius: 50%;
            width: 25px;
            height: 25px;
            position: absolute;
            left: -49px;
            top: 15px;
            background: #242a37;
        }

        .timeline-section .timeline-item::after {
            content: "";
            width: 25px;
            height: 3px;
            position: absolute;
            left: -25px;
            top: 26px;
            background: #ff8900;
        }
    }


</style>