---
import {getLang, translate} from "../i18n";
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Nav.astro';

const lang = getLang(Astro.url);
const t = translate(lang);
---

<Layout title="Flavius Cojocariu | Web developer - resume">
    <Navbar defaultActiveItem="GDPR"></Navbar>
    <main class="container text-light">
        <div id="resume" class="d-flex px-1 py-5 justify-content-center section-height section col-12">
            <div class="d-flex flex-fill flex-column align-items-center g-5 py-5 col-sm-12">
                <div class="col-lg-12">
                    <p class="fs-1 mb-3 flex-fill text-warning fw-light text-center section-title d-print-none">
                        {t("gdpr.title")}
                    </p>
                </div>
                <div class="d-flex flex-column mb-3 justify-content-center align-items-center align-self-center col-12">
                    <div class="d-flex flex-column justify-content-center p-5 align-items-center align-self-center col-10">
                        <p class="h2">1. Allgemeine Hinweise</p>

                        <p class="mb-4">Der Schutz Ihrer persönlichen Daten ist mir ein besonderes Anliegen. Diese Website
                            erhebt <strong>keine personenbezogenen Daten</strong>, verwendet <strong>keine Cookies</strong>,
                            <strong>keine Tracker</strong>, und <strong>keine Analyse-Tools</strong>.</p>

                        <p class="h2">2. Verantwortlicher</p>

                        <p class="mb-0"><strong>Flavius Cojocariu</strong></p>
                        <p class="mb-0">[Deine Straße und Hausnummer]</p>
                        <p class="mb-0">82538 Geretsried</p>
                        <p class="mb-0">Deutschland</p>
                        <p class="mb-4">info@flaviuscojocariu.com</p>

                        <p class="h2">3. Hosting über GitLab Pages</p>

                        <p class="mb-3">Diese Website wird über <strong>GitLab Pages</strong> bereitgestellt. Beim Aufruf
                            der Seiten werden automatisch Informationen in sogenannten Server-Log-Dateien gespeichert. Dazu
                            gehören z. B.:</p>

                        <p class="mb-0">- Browsertyp und -version</p>
                        <p class="mb-0">- Verwendetes Betriebssystem</p>
                        <p class="mb-0">- Referrer URL</p>
                        <p class="mb-0">- IP-Adresse (ggf. anonymisiert)</p>
                        <p class="mb-4">- Uhrzeit der Serveranfrage</p>

                        <p class="mb-4">Diese Daten dienen ausschließlich der technischen Bereitstellung der Website und
                            werden nicht personenbezogen ausgewertet.</p>

                        <p class="mb-4">Weitere Informationen finden Sie in der <a
                                href="https://about.gitlab.com/privacy/" class="text-warning">Datenschutzerklärung von
                            GitLab Inc.</a> sowie in den <a href="https://about.gitlab.com/security/gdpr/"
                                                            class="text-warning">Informationen zur DSGVO-Konformität</a>.
                        </p>

                        <p class="h2">4. DNS-Management über Cloudflare</p>

                        <p class="mb-4">Die Domain dieser Website wird über <strong>Cloudflare</strong> verwaltet.
                            Cloudflare kann technische Daten wie IP-Adressen verarbeiten, um eine sichere und schnelle
                            Auslieferung der Website zu gewährleisten.
                            Mehr dazu in der <a href="https://www.cloudflare.com/de-de/privacypolicy/" class="text-warning">Datenschutzerklärung
                                von Cloudflare</a>.</p>

                        <p class="h2">5. Ihre Rechte</p>

                        <p class="mb-4">Sie haben das Recht auf Auskunft über die bei uns gespeicherten personenbezogenen
                            Daten sowie auf Berichtigung, Löschung oder Einschränkung der Verarbeitung nach Art. 15 ff.
                            DSGVO.</p>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <Footer></Footer>
</Layout>

<style>
    .section-title {
        position: relative;
        padding-bottom: 8px;
    }

    .section-title::after {
        position: absolute;
        margin-left: auto;
        margin-right: auto;
        left: 0;
        right: 0;
        text-align: center;
        bottom: 0;
        width: 5vh;
        height: 1px;
        border-bottom: 7px solid #ffcc00;
        content: "";
    }

    .timeline-section {
        width: 100%;
        padding: 8px 8px 8px 25px;
    }

    .timeline-section .timeline-item {
        padding: 16px;
        margin: 16px 16px 16px 25px;
        width: 100%;
        background: #242a37;
        line-height: 2.5em !important;
    }

    .timeline-item-body, .timeline-item-body ul > li {
        padding: 8px;
        line-height: 1.75em !important;
    }

    .vh-5 {
        height: 5vh;
    }

    .max-vh-5 {
        max-height: 5vh;
    }

    .min-vh-5 {
        min-height: 5vh;
    }

    @media screen and (min-width: 900px) {

        .timeline-section {
            width: 100%;
        }

        .timeline-item {
            width: 750px;
            min-width: 750px;
            border: 2px solid #ff8900;
            position: relative;
        }

        .timeline-section {
            border-left: 5px solid #ff8900;
            padding-left: 8px;
        }

        .timeline-section .timeline-item::before {
            content: "";
            border: 3px solid #ff8900;
            border-radius: 50%;
            width: 25px;
            height: 25px;
            position: absolute;
            left: -49px;
            top: 15px;
            background: #242a37;
        }

        .timeline-section .timeline-item::after {
            content: "";
            width: 25px;
            height: 3px;
            position: absolute;
            left: -25px;
            top: 26px;
            background: #ff8900;
        }
    }


</style>
