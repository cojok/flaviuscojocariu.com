---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Nav.astro';
import {getLang, translate} from "../../i18n";
const lang = getLang(Astro.url);
const t = translate(lang);
type section = {
    id?: string;
    title: string;
    year: string;
    employer: string;
    body?: string;
    bodyList?: Array<string>;
    technologies?: string[];
};
type content = {
    title: string;
    sections: section[];
}
const education: content = {
    title: 'Studium',
    sections: [{
        title: 'Informatik',
        employer: 'West-Universität von Timisoara, Rumänien',
        year: '2009-2012',
        body: 'BA, Entwicklung einer Web-App'
    }]
};

const workExperience: content = {
    title: 'Work Experience',
    sections: [
        {
            id: 'iu-group-em',
            title: 'Engineering Manager → Senior Engineering Manager (Platform Ownership)',
            employer: 'IU Group N.V., München, Germany',
            year: 'Januar 2024 - heute',
            bodyList: [
                'Leitet <span class="fw-bold">zwei Engineering-Teams</span> (7 Engineers) mit <span class="fw-bold">vollständiger dual Ownership</span> über MyCampus Classic (Moodle) und MyCampus 2.0 - für über <span class="fw-bold">100.000 Studierende</span> an Deutschlands größter Universität.',
                'Konsolidierung von <span class="fw-bold">15+ Repos</span> in ein gemeinsames NestJS-Monorepo, Reduzierung des Wartungsaufwands um <span class="fw-bold">~45%</span> und Verbesserung der Team-Mobilität; Microfrontends von <span class="fw-bold">15 auf 10</span> reduziert.',
                'Einführung von <span class="fw-bold">Observability</span> und <span class="fw-bold">DORA-Metriken</span> mit <span class="fw-bold">~60% proaktiver Fehlererkennung</span>; erste <span class="fw-bold">zero-downtime, zero-incident Haupteinschreibung</span> seit über 8 Jahren (Oktober 2025).',
                '<span class="fw-bold">~90% der Studierenden</span> erfolgreich zu MyCampus 2.0 migriert bei gleichzeitigem Betrieb der Classic-Plattform.',
                'Co-Design der <span class="fw-bold">Datenflussarchitektur</span> mit zwei peer Heads of Engineering; ausgewählt für die <span class="fw-bold">unternehmensweite Datenvereinheitlichungs-Taskforce</span> neben HoEs und Directors.',
                'Team durch <span class="fw-bold">3 Reorgs ohne Fluktuation</span> geführt - durch strukturiertes <span class="fw-bold">Change Management</span>, <span class="fw-bold">Coaching</span> und <span class="fw-bold">1:1-Entwicklung</span>.',
                'Regelmäßiger Beitrag zu quartalsweisen <span class="fw-bold">HoE-Alignment-Meetings</span> mit dem Director of Engineering zu plattformübergreifender Strategie.',
            ],
            technologies: [
                "TypeScript", "NestJS", "Vue 3", "Moodle 4", "Docker", "GitLab CI/CD",
                "Node.js", "Fastify", "Cypress", "Jest", "OpenAPI", "Kafka", "K6", "PHP"
            ]
        },
        {
            id: 'remberg-sswe',
            title: 'Senior Software Engineer',
            employer: 'remberg GmbH, München, Germany',
            year: 'Januar, 2022 - Dezember, 2023',
            bodyList: [
                'Aktive Beteiligung an <span class="fw-bold">technischen Gesprächen</span> und Mitwirkung bei der <span class="fw-bold">architektonischen Entscheidungsfindung</span>.',
                'Verbesserung der Code-Qualität durch Überarbeitung von <span class="fw-bold">Backend-Funktionen in NestJS</span> und das Durchführen von <span class="fw-bold">Code-Überprüfungen</span>.',
                'Übernahme der Rolle des <span class="fw-bold">Hauptentwicklers in zwei wichtigen Projekten</span>. Migration der E-Mail-Funktionalität von <span class="fw-bold">Mailgun zu AWS SES</span> und Hinzufügung neuer Funktionen zur <span class="fw-bold">Dateiverwaltung</span>, einschließlich der Erstellung einer <span class="fw-bold">Ordnerstruktur</span>. Treffen entscheidender <span class="fw-bold">architektonischer Entscheidungen</span> und Auswahl geeigneter Technologien zur Unterstützung der Skalierbarkeit.',
                'Teilnahme am <span class="fw-bold">Einstellungsprozess</span> durch Durchführung von <span class="fw-bold">technischen Interviews</span>. Unterstützung bei der Integration neuer Teammitglieder und Vertrautmachen mit der aktuellen Software- und Systemarchitektur.',
            ],
            technologies: ['Typescript', 'NestJS', 'ExpressJs', 'Mongoose', 'Docker', 'NxJs', 'MongoDB', 'OpenAPI', 'Angular >=v14', 'NgRX', 'Angular Material UI', 'Jest', 'CypressJS', 'SCSS', 'Agile Development, Jira, Gitlab, Docker']
        },
        {
            id: 'ryd-swe-lbe',
            title: 'Software Engineer - Lead Backend Engineer',
            employer: 'ThinxNet GmbH, München, Germany',
            year: 'Juni, 2019 - Dezember, 2021',
            bodyList: [
                'Weiterentwicklung des <span class="fw-bold">API-Gateways</span> und Umstellung von alten monolithischen Funktionen auf neue <span class="fw-bold">Microservices</span>.',
                'Tägliche Codebase-Wartung und Refactoring, Modernisierung älterer Webanwendungen (<span class="fw-bold">Frontend und Backend</span>) mit aktuellen Technologien.',
                'Implementierung von <span class="fw-bold">MVPs</span> und <span class="fw-bold">Proof of Concepts</span>.',
                'Aufbau eines <span class="fw-bold">Backend-Teams von 5 Personen</span> von Grund auf, aktive Beteiligung am <span class="fw-bold">Einstellungsprozess</span>, um die Übereinstimmung mit der Vision des Unternehmens sicherzustellen.',
                'Onboarding von Teammitgliedern und Einarbeitung in die aktuellen Software- und <span class="fw-bold">Systemarchitekturen</span>.',
                'Zusammenarbeit mit <span class="fw-bold">Product Ownern</span> und dem <span class="fw-bold">Head of Software</span> bei der Planung von Sprint Backlogs, um die Unternehmensziele zu erreichen.',
                '<span class="fw-bold">Betreuung jüngerer Entwickler</span>, Anleitung des Teams bei technischen Herausforderungen und Beaufsichtigung von <span class="fw-bold">Systemverbesserungen</span>.',
            ],
            technologies: ['Javascript/Typescript/Node/Express/NestJS/Mongoose/TypeORM',
                'MongoDB/PostgreSQL/Redis/RabbitMQ/Kafka/API-Gateway', 'Mocha/Chai/Sinon/Jest',
                'bash/lwc', 'HTML/SCSS/Vuejs', 'Agile Development, Jira, Gitlab, Docker']
        },
        {
            id: 'travador-fwd',
            title: 'Fullstack Web Developer',
            employer: 'Travador GmbH, München, Germany',
            year: 'November, 2016 - Mai, 2019',
            bodyList: [
                'Entwicklung und Implementierung <span class="fw-bold">neuer Funktionen und UI-Komponenten</span> in Zusammenarbeit mit der Design-Abteilung.',
                'Tägliche Systempflege und <span class="fw-bold">Code-Refactoring</span> für die bestehende Code-Basis.',
                'Leitung des Planungsprozesses für die Verbesserung der <span class="fw-bold">Buchungsplattform</span>, der Website und der <span class="fw-bold">Full-Stack-Microservices</span>-Entwicklung.',
            ],
            technologies: ['HTML5/CSS3(Twig, SCSS, EJS)', 'Javascript/ES6/Vuejs/jQuery/AngularJS/Nodejs/Webpack',
                'CakePHP/CackeLaravel/Lumen/MySQL/', 'AWS(Lambda, S3, Cloudfront)', 'Agile, Jira, Git']

        },
        {
            id: 'early-wd',
            title: 'Web Developer',
            employer: 'SMAL GmbH, Toluna Group, Seopa Ltd, BLIPhead GmbH',
            year: 'April, 2012 - Oktober, 2016',
            bodyList: [
                'Entwicklung von <span class="fw-bold">responsiven Prototypen</span>, Marketing-Seiten und <span class="fw-bold">Webanwendungen</span> für Agentur- und Inhouse-Kunden.',
                'Aufbau und Wartung von <span class="fw-bold">PHP/MySQL-Backends</span>; Bereitstellung von <span class="fw-bold">hybriden mobilen Features</span> und <span class="fw-bold">Server-Wartung</span>.',
                'Erstellung einer internen <span class="fw-bold">Wissensdatenbank</span> mit wiederverwendbaren Code-Snippets; Durchführung von <span class="fw-bold">Code-Reviews</span> und <span class="fw-bold">Kundenplanungssitzungen</span>.',
            ],
            technologies: ['HTML5', 'CSS3', 'JavaScript', 'jQuery', 'AngularJS', 'PHP (CakePHP)', 'MySQL', 'Drupal']
        },
    ]
};
---

<Layout title="Flavius Cojocariu | Engineering Leader - Lebenslauf">
    <Navbar defaultActiveItem={t('nav.resume')}></Navbar>
    <main class="container text-light">
        <div id="resume" class="d-flex px-1 py-5 justify-content-center section-height section col-12">
            <div class="d-flex flex-fill flex-column align-items-center g-5 py-5 col-sm-12">
                <div class="col-lg-12">
                    <p class="fs-1 mb-3 flex-fill text-warning fw-light text-center section-title d-print-noneä">
                        {t("resume.title")}
                    </p>
                </div>
                <div class="d-flex flex-column mb-3 justify-content-center align-items-center align-self-center col-12">
                    <div class="d-flex flex-column justify-content-center p-5 align-items-center align-self-center col-10">
                        <p class="fs-3 mb-3 text-warning fw-light text-center vh-5 max-vh-5 min-vh-5 d-print-none">
                            {workExperience.title}
                            <br/>
                            <a href="javascript:window.print();"  class="fs-4 ms-2 text-warning d-print-none">
                                {t('resume.download')}
                            </a>
                        </p>
                        <div class="fs-6 timeline-section d-flex flex-column">
                            {
                                workExperience.sections.map((section) => (
                                        <div class="timeline-item d-flex flex-column justify-content-around align-items-center"
                                             id={section.id}>
                                            <span class="fs-3">{section.title}</span>
                                            <span class="fs-4">{section.employer}</span>
                                            <span class="fs-4">{section.year}</span>
                                            <span class="timeline-item-body">
                                                <ul>
                                                    {
                                                        section.bodyList?.map((item) => (
                                                                <li set:html={item}></li>
                                                        ))
                                                    }
                                                </ul>
                                            </span>
                                            <span>
                                                {t('resume.techUsed')}:
                                                {
                                                    section.technologies?.map((item) => (
                                                            <span class="badge bg-secondary m-1 text-dark"> &nbsp;{item}&nbsp; </span>
                                                    ))
                                                }
                                            </span>
                                        </div>
                                ))
                            }
                        </div>
                    </div>
                </div>
                <div class="d-flex flex-column mb-3 justify-content-center align-items-center align-self-center col-12">
                    <div class="d-flex flex-column justify-content-center p-5 align-items-center align-self-center col-10">
                        <p class="fs-3 mb-3 text-warning fw-light text-center vh-5 max-vh-5 min-vh-5">
                            {education.title}
                        </p>
                        <div class="fs-6 timeline-section d-flex flex-column">
                            {
                                education.sections.map((section) => (
                                        <div class="timeline-item d-flex flex-column justify-content-around align-items-center">
                                            <span class="fs-3">{section.title}</span>
                                            <span class="fs-4">{section.employer}</span>
                                            <span class="fs-4">{section.year}</span>
                                            <span class="timeline-item-body">
                                                {section.body}
                                            </span>
                                        </div>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <Footer></Footer>
</Layout>

<style>
    .section-title {
        position: relative;
        padding-bottom: 8px;
    }

    .section-title::after {
        position: absolute;
        margin-left: auto;
        margin-right: auto;
        left: 0;
        right: 0;
        text-align: center;
        bottom: 0;
        width: 5vh;
        height: 1px;
        border-bottom: 7px solid #ffcc00;
        content: "";
    }

    .timeline-section {
        width: 100%;
        padding: 8px 8px 8px 25px;
    }

    .timeline-section .timeline-item {
        padding: 16px;
        margin: 16px 16px 16px 25px;
        width: 100%;
        background: #242a37;
        line-height: 2.5em !important;
    }

    .timeline-item-body, .timeline-item-body ul > li {
        padding: 8px;
        line-height: 1.75em !important;
    }

    .vh-5 {
        height: 5vh;
    }

    .max-vh-5 {
        max-height: 5vh;
    }

    .min-vh-5 {
        min-height: 5vh;
    }

    .badge.bg-primary {
        background: #f1f2f6 !important;
        margin: 4px;
    }

    @media screen and (min-width: 900px) {

        .timeline-section {
            width: 100%;
        }

        .timeline-item {
            width: 750px;
            min-width: 750px;
            border: 2px solid #ff8900;
            position: relative;
        }

        .timeline-section {
            border-left: 5px solid #ff8900;
            padding-left: 8px;
        }

        .timeline-section .timeline-item::before {
            content: "";
            border: 3px solid #ff8900;
            border-radius: 50%;
            width: 25px;
            height: 25px;
            position: absolute;
            left: -49px;
            top: 15px;
            background: #242a37;
        }

        .timeline-section .timeline-item::after {
            content: "";
            width: 25px;
            height: 3px;
            position: absolute;
            left: -25px;
            top: 26px;
            background: #ff8900;
        }
    }

</style>