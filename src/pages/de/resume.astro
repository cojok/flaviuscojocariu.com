---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Nav.astro';
import {getLang, translate} from "../../i18n";
const lang = getLang(Astro.url);
const t = translate(lang);
type section = {
    id?: string;
    title: string;
    year: string;
    employer: string;
    body?: string;
    bodyList?: Array<string>;
    technologies?: string[];
};
type content = {
    title: string;
    sections: section[];
}
const education: content = {
    title: 'Studium',
    sections: [{
        title: 'Informatik',
        employer: 'West-Universität von Timisoara, Rumänien',
        year: '2009-2012',
        body: 'BA, Entwicklung einer Web-App'
    }]
};

const workExperience: content = {
    title: 'Work Experience',
    sections: [
        {
            id: 'iu-group-em',
            title: 'Engineering Manager',
            employer: 'IU Group, München, Germany',
            year: 'January, 2024 - Present',
            bodyList: [
                "Durchführung von <span class=\"fw-bold\">Code-Reviews</span>, <span class=\"fw-bold\">kleinen Entwicklungsaufgaben</span> und <span class=\"fw-bold\">Pair Programming</span>, um das Team bei kleineren Fehlerbehebungen oder Konfigurationen zu unterstützen.",
