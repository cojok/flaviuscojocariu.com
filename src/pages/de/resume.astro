                "Typescript", "NestJS", "Mongoose", "Docker", "MySQL", "MongoDB",
                "OpenAPI", "Vue.js v3", "SingleSPA", "Node.js", "Fastify",
                "JavaScript", "CI/CD", "GitLab CI/CD", "DORA Metrics", "CypressJS",
                "Jest", "SCSS", "HTML5", "XP+Scrum", "Agile", "Jira", "GitLab"
