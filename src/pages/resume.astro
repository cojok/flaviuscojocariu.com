---
import {getLang, translate} from "../i18n";
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Nav.astro';
type section = {
    id: string,
    title: string;
    year: string;
    employer: string;
    body?: string;
    bodyList?: Array<string>;
    technologies?: string[];
};
type content = {
    title: string;
    sections: section[];
}

const lang = getLang(Astro.url);
const t = translate(lang);

const education: content = {
    title: 'Education',
    sections: [{
        id: 'wu-tm-edu',
        title: 'Computer Science Studies',
        employer: 'West University, Timisoara, Romania',
        year: '2009-2012',
        body: 'BA: Development of an Web App'
    }]
};

const workExperience: content = {
    title: 'Work Experience',
    sections: [
        {
            id: 'iu-group-em',
            title: 'Engineering Manager → Senior Engineering Manager (Platform Ownership)',
            employer: 'IU Group N.V., München, Germany',
            year: 'January, 2024 - Present',
            bodyList: [
                'Leads <span class="fw-bold">two engineering teams</span> (7 engineers) with <span class="fw-bold">full dual ownership</span> of MyCampus Classic (Moodle) and MyCampus 2.0 - serving <span class="fw-bold">100,000+ students</span> at Germany\'s largest university.',
                'Consolidated <span class="fw-bold">15+ repos</span> into a shared NestJS monorepo, reducing maintenance overhead by <span class="fw-bold">~45%</span> and improving team mobility across both platforms; reduced microfrontends from <span class="fw-bold">15 to 10</span>.',
                'Introduced <span class="fw-bold">observability</span> and <span class="fw-bold">DORA-aligned metrics</span> achieving <span class="fw-bold">~60% proactive issue detection</span>; delivered the first <span class="fw-bold">zero-downtime, zero-incident major student intake</span> in 8+ years (October 2025).',
                'Drove <span class="fw-bold">~90% student migration</span> to MyCampus 2.0 while maintaining full Classic platform stability in parallel.',
                'Co-designing <span class="fw-bold">data flow architecture</span> with two peer Heads of Engineering; selected for the <span class="fw-bold">cross-company data unification task force</span> alongside HoEs and Directors.',
                'Rebuilt team structure through <span class="fw-bold">3 reorgs with zero attrition</span> - through structured <span class="fw-bold">change management</span>, <span class="fw-bold">coaching</span>, and <span class="fw-bold">1:1 development</span>.',
                'Regular contributor to quarterly <span class="fw-bold">HoE alignment</span> with the Director of Engineering on cross-platform strategy and org planning.',
            ],
            technologies: [
                "TypeScript", "NestJS", "Vue 3", "Moodle 4", "Docker", "GitLab CI/CD",
                "Node.js", "Fastify", "Cypress", "Jest", "OpenAPI", "Kafka", "K6", "PHP"
            ]
        },
        {
            id: 'remberg-sswe',
            title: 'Senior Software Engineer',
            employer: 'remberg GmbH, München, Germany',
            year: 'January, 2022 - December, 2023',
            bodyList: [
                'Engaging in <span class="fw-bold">technical discussions</span> and contributing to <span class="fw-bold">architectural decision-making</span>.',
                'Refactoring and improving code quality by rewriting <span class="fw-bold">backend features to NestJS</span> and conducting <span class="fw-bold">code reviews</span>.',
                'Assuming the role of <span class="fw-bold">lead developer on two key projects</span>, involving the migration of email functionality from <span class="fw-bold">Mailgun to AWS SES</span> and the addition of new capabilities to the <span class="fw-bold">file management feature</span>, including the implementation of a <span class="fw-bold">folder structure</span>. Making pivotal <span class="fw-bold">architectural decisions</span> and choosing the most suitable technologies to address project requirements and support software scalability.',
                'Participating in the <span class="fw-bold">hiring process</span> by conducting screening and <span class="fw-bold">technical interviews</span>. Assisting in onboarding new team members to the projects and acquainting them with the current software and system architectures.',
            ],
            technologies: ['Typescript', 'NestJS', 'ExpressJs', 'Mongoose', 'Docker', 'NxJs', 'MongoDB', 'OpenAPI', 'Angular >=v14', 'NgRX', 'Angular Material UI', 'Jest', 'CypressJS', 'SCSS', 'Agile Development, Jira, Gitlab, Docker']
        },
        {
            id: 'ryd-swe-lbe',
            title: 'Software Engineer - Lead Backend Engineer',
            employer: 'ThinxNet GmbH, München, Germany',
            year: 'June, 2019 - December, 2021',
            bodyList: [
                'Advancing the <span class="fw-bold">API-Gateway</span> and transitioning old monolith features to new <span class="fw-bold">Microservices</span>.',
                'Daily codebase maintenance and refactoring, modernizing older web applications (<span class="fw-bold">frontend and backend</span>) with updated technologies.',
                'Implementing <span class="fw-bold">MVPs</span> and <span class="fw-bold">proof of concepts</span>.',
                'Building a <span class="fw-bold">backend team of 5 from scratch</span>, actively involved in the <span class="fw-bold">hiring process</span> to ensure alignment with the company\'s vision.',
                'Onboarding team members and familiarizing them with current software and <span class="fw-bold">system architectures</span>.',
                'Collaborating with <span class="fw-bold">Product Owners</span> and the <span class="fw-bold">Head of Software</span> to plan sprint backlogs to meet company goals.',
                '<span class="fw-bold">Mentoring junior developers</span>, guiding the team through technical challenges, and overseeing <span class="fw-bold">system enhancements</span>.',
            ],
            technologies: ['Javascript/Typescript/Node/Express/NestJS/Mongoose/TypeORM',
                'MongoDB/PostgreSQL/Redis/RabbitMQ/Kafka/API-Gateway', 'Mocha/Chai/Sinon/Jest',
                'bash/lwc', 'HTML/SCSS/Vuejs', 'Agile Development, Jira, Gitlab, Docker']
        },
        {
            id: 'travador-fwd',
            title: 'Fullstack Web Developer',
            employer: 'Travador GmbH, München, Germany',
            year: 'November, 2016 - May, 2019',
            bodyList: [
                'Developing and implementing <span class="fw-bold">new features and UI components</span> in collaboration with the design department.',
                'Daily maintenance and <span class="fw-bold">code refactoring</span> for the existing codebase.',
                'Leading the planning process for enhancing the <span class="fw-bold">booking platform</span>, website, and <span class="fw-bold">full-stack Microservices</span> development.',
            ],
            technologies: ['HTML5/CSS3(Twig, SCSS, EJS)', 'Javascript/ES6/Vuejs/jQuery/AngularJS/Nodejs/Webpack',
                'CakePHP/CackeLaravel/Lumen/MySQL/', 'AWS(Lambda, S3, Cloudfront)', 'Agile, Jira, Git']

        },
        {
            id: 'early-wd',
            title: 'Web Developer',
            employer: 'SMAL GmbH, Toluna Group, Seopa Ltd, BLIPhead GmbH',
            year: 'April, 2012 - October, 2016',
            bodyList: [
                'Developed <span class="fw-bold">responsive prototypes</span>, marketing sites, and <span class="fw-bold">web applications</span> for agency and in-house clients.',
                'Built and maintained <span class="fw-bold">PHP/MySQL backends</span>; deployed <span class="fw-bold">hybrid mobile features</span> and performed <span class="fw-bold">server maintenance</span>.',
                'Created an internal <span class="fw-bold">knowledge base</span> with reusable code snippets; conducted <span class="fw-bold">code reviews</span> and <span class="fw-bold">client planning sessions</span>.',
            ],
            technologies: ['HTML5', 'CSS3', 'JavaScript', 'jQuery', 'AngularJS', 'PHP (CakePHP)', 'MySQL', 'Drupal']
        },
    ]
};
---

<Layout title="Flavius Cojocariu | Resume">
    <Navbar defaultActiveItem="Resume"></Navbar>
    <main class="container text-light">
        <div id="resume" class="d-flex px-1 py-5 justify-content-center section-height section col-12">
            <div class="d-flex flex-fill flex-column align-items-center g-5 py-5 col-sm-12">
                <div class="col-lg-12">
                    <p class="fs-1 mb-3 flex-fill text-warning fw-light text-center section-title d-print-none">
                        {t("resume.title")}
                    </p>
                </div>
                <div class="d-flex flex-column mb-3 justify-content-center align-items-center align-self-center col-12">
                    <div class="d-flex flex-column justify-content-center p-5 align-items-center align-self-center col-10">
                        <p class="fs-3 mb-3 text-warning fw-light text-center vh-5 max-vh-5 min-vh-5 d-print-none">
                            {workExperience.title}
                            <br/>
                            <a href="javascript: window.print();" class="fs-4 ms-2 text-warning d-print-none">
                                {t('resume.download')}
                            </a>
                        </p>
                        <div class="fs-6 timeline-section d-flex flex-column">
                            {
                                workExperience.sections.map((section: section) => (
                                        <div class="timeline-item d-flex flex-column justify-content-around align-items-center" id={section.id}>
                                            <span class="fs-3">{section.title}</span>
                                            <span class="fs-4">{section.employer}</span>
                                            <span class="fs-4">{section.year}</span>
                                            <span class="timeline-item-body">
                                                <ul>
                                                    {
                                                        section.bodyList?.map((item) => (
                                                                <li set:html={item}></li>
                                                        ))
                                                    }
                                                </ul>
                                            </span>
                                            <span>
                                                {t('resume.techUsed')}:
                                                {
                                                    section.technologies?.map((item) => (
                                                            <span class="badge bg-secondary m-1 text-dark"> &nbsp;{item}&nbsp; </span>
                                                    ))
                                                }
                                            </span>
                                        </div>
                                ))
                            }
                        </div>
                    </div>
                </div>
                <div class="d-flex flex-column mb-3 justify-content-center align-items-center align-self-center col-12">
                    <div class="d-flex flex-column justify-content-center p-5 align-items-center align-self-center col-10">
                        <p class="fs-3 mb-3 text-warning fw-light text-center vh-5 max-vh-5 min-vh-5">
                            {education.title}
                        </p>
                        <div class="fs-6 timeline-section d-flex flex-column">
                            {
                                education.sections.map((edSection: section) => (
                                        <div class="timeline-item d-flex flex-column justify-content-around align-items-center" id={edSection.id}>
                                            <span class="fs-3">{edSection.title}</span>
                                            <span class="fs-4">{edSection.employer}</span>
                                            <span class="fs-4">{edSection.year}</span>
                                            <span class="timeline-item-body">
                                                {edSection.body}
                                            </span>
                                        </div>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <Footer></Footer>
</Layout>

<style>
    .section-title {
        position: relative;
        padding-bottom: 8px;
    }

    .section-title::after {
        position: absolute;
        margin-left: auto;
        margin-right: auto;
        left: 0;
        right: 0;
        text-align: center;
        bottom: 0;
        width: 5vh;
        height: 1px;
        border-bottom: 7px solid #ffcc00;
        content: "";
    }

    .timeline-section {
        width: 100%;
        padding: 8px 8px 8px 25px;
    }

    .timeline-section .timeline-item {
        padding: 16px;
        margin: 16px 16px 16px 25px;
        width: 100%;
        background: #242a37;
        line-height: 2.5em !important;
    }

    .timeline-item-body, .timeline-item-body ul > li {
        padding: 8px;
        line-height: 1.75em !important;
    }

    .vh-5 {
        height: 5vh;
    }

    .max-vh-5 {
        max-height: 5vh;
    }

    .min-vh-5 {
        min-height: 5vh;
    }

    @media screen and (min-width: 900px) {

        .timeline-section {
            width: 100%;
        }

        .timeline-item {
            width: 750px;
            min-width: 750px;
            border: 2px solid #ff8900;
            position: relative;
        }

        .timeline-section {
            border-left: 5px solid #ff8900;
            padding-left: 8px;
        }

        .timeline-section .timeline-item::before {
            content: "";
            border: 3px solid #ff8900;
            border-radius: 50%;
            width: 25px;
            height: 25px;
            position: absolute;
            left: -49px;
            top: 15px;
            background: #242a37;
        }

        .timeline-section .timeline-item::after {
            content: "";
            width: 25px;
            height: 3px;
            position: absolute;
            left: -25px;
            top: 26px;
            background: #ff8900;
        }
    }


</style>
